{{> header title='Civilización' page='civilizacion'}}

<main>

    <h1 class="section-title" style="margin-bottom:0.5rem;">Estado de la Civilización</h1>
    <p style="color:var(--text-muted); margin-bottom:2.5rem;">
        Datos actualizados en tiempo real desde la base de datos.
    </p>

    {{#unless civ}}
        <div class="card" style="text-align:center; padding:3rem; color:var(--text-muted);">
            <div style="font-size:3rem; margin-bottom:1rem;">🏰</div>
            <p>No se encontraron datos de la civilización en la base de datos.</p>
        </div>
    {{else}}

    <div class="divider divider-graphic">
        <div class="divider-line"></div>
        <img src="/img/gemas.png" alt="diamante" class="divider-image">
        <div class="divider-line"></div>
    </div>

    <h2 class="section-title">Recursos actuales</h2>

    <div class="grid-3" style="margin-bottom:2.5rem;">
        <div class="stat-box">
            <span class="stat-icon">🌾</span>
            <span class="stat-label">Comida</span>
            <span class="stat-value">{{numberFormat civ.food_amount}}</span>
        </div>
        <div class="stat-box">
            <span class="stat-icon">🪵</span>
            <span class="stat-label">Madera</span>
            <span class="stat-value">{{numberFormat civ.wood_amount}}</span>
        </div>
        <div class="stat-box">
            <span class="stat-icon">⚙</span>
            <span class="stat-label">Hierro</span>
            <span class="stat-value">{{numberFormat civ.iron_amount}}</span>
        </div>
        <div class="stat-box">
            <span class="stat-icon">✨</span>
            <span class="stat-label">Maná</span>
            <span class="stat-value">{{numberFormat civ.mana_amount}}</span>
        </div>
        <div class="stat-box">
            <span class="stat-icon">⚔</span>
            <span class="stat-label">Tecnología Ataque</span>
            <span class="stat-value">Nivel {{default civ.technology_attack_level 0}}</span>
        </div>
        <div class="stat-box">
            <span class="stat-icon">🛡</span>
            <span class="stat-label">Tecnología Defensa</span>
            <span class="stat-value">Nivel {{default civ.technology_defense_level 0}}</span>
        </div>
    </div>

    <div class="divider divider-graphic">
        <div class="divider-line"></div>
        <img src="/img/tower.png" alt="Icono de Construcción" class="divider-image">
        <div class="divider-line"></div>
    </div>

    <h2 class="section-title">Edificios</h2>

    <div class="grid-3" style="margin-bottom:2.5rem;">

        <div class="card">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                <span style="font-size:1.5rem;">🌾</span>
                <span class="stat-label">Granjas</span>
            </div>
            <div class="stat-value" style="font-size:2rem;">{{default civ.farm_counter 0}}</div>
            <div class="progress-bar" style="margin-top:0.75rem;">
                <div class="progress-fill" style="width: {{progress civ.farm_counter 10}}%"></div>
            </div>
            <p class="stat-sub" style="margin-top:0.5rem;">+{{multiply civ.farm_counter 5}}% generación de comida</p>
        </div>

        <div class="card">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                <span style="font-size:1.5rem;">⚒</span>
                <span class="stat-label">Herrerías</span>
            </div>
            <div class="stat-value" style="font-size:2rem;">{{default civ.smithy_counter 0}}</div>
            <div class="progress-bar" style="margin-top:0.75rem;">
                <div class="progress-fill" style="width: {{progress civ.smithy_counter 10}}%"></div>
            </div>
            <p class="stat-sub" style="margin-top:0.5rem;">+{{multiply civ.smithy_counter 5}}% generación de hierro</p>
        </div>

        <div class="card">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                <span style="font-size:1.5rem;">🪚</span>
                <span class="stat-label">Carpinterías</span>
            </div>
            <div class="stat-value" style="font-size:2rem;">{{default civ.carpentry_counter 0}}</div>
            <div class="progress-bar" style="margin-top:0.75rem;">
                <div class="progress-fill" style="width: {{progress civ.carpentry_counter 10}}%"></div>
            </div>
            <p class="stat-sub" style="margin-top:0.5rem;">+{{multiply civ.carpentry_counter 5}}% generación de madera</p>
        </div>

        <div class="card">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                <span style="font-size:1.5rem;">🔮</span>
                <span class="stat-label">Torres Mágicas</span>
            </div>
            <div class="stat-value" style="font-size:2rem;">{{default civ.magicTower_counter 0}}</div>
            <p class="stat-sub" style="margin-top:0.5rem;">
                Maná: +{{multiply civ.magicTower_counter 3000}} por ciclo
            </p>
        </div>

        <div class="card">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                <span style="font-size:1.5rem;">⛪</span>
                <span class="stat-label">Iglesias</span>
            </div>
            <div class="stat-value" style="font-size:2rem;">{{default civ.church_counter 0}}</div>
            <p class="stat-sub" style="margin-top:0.5rem;">
                Permite hasta {{default civ.church_counter 0}} sacerdote(s)
            </p>
        </div>

        <div class="card">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                <span style="font-size:1.5rem;">⚔</span>
                <span class="stat-label">Batallas jugadas</span>
            </div>
            <div class="stat-value" style="font-size:2rem;">{{default civ.battles_counter 0}}</div>
            <p class="stat-sub" style="margin-top:0.5rem;">
                El ejército enemigo se fortalece cada batalla.
            </p>
        </div>

    </div>

    {{/unless}}

</main>

{{> footer}}