<footer>
    <div class="footer-inner">
        <div class="footer-logo">⚔ CIVILIZATIONS ⚔</div>
        <p class="footer-legal">
            &copy; {{year}} Projecte AMS i AWS &mdash;
            Tots els drets reservats. Projecte educatiu sense ànim de lucre.
        </p>

        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 10px; opacity: 0.7;">
            Música: <strong>"Epic"</strong> por 
            <a href="https://www.creatorchords.com" target="_blank" style="color: inherit; text-decoration: underline;">
                Alexander Nakarada
            </a>.
        </p>
    </div>

    <div class="audio-control" style="position: fixed; bottom: 20px; right: 20px; z-index: 1000;">
        <button id="music-toggle" class="btn" style="border-radius: 50px; padding: 10px 25px; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.6); font-weight: bold; cursor: pointer;">
            <span id="music-icon">▶️</span>
            <span id="music-text">Play Música</span>
        </button>
        <audio id="bg-music" loop>
            <source src="/audio/epic.mp3" type="audio/mpeg">
        </audio>
    </div>

    <script>
        const audio = document.getElementById('bg-music');
        const btn = document.getElementById('music-toggle');
        const icon = document.getElementById('music-icon');
        const text = document.getElementById('music-text');

        // Función para actualizar el estilo visual del botón
        function actualizarInterfaz(playing) {
            icon.innerText = playing ? "⏸️" : "▶️";
            text.innerText = playing ? "Pausa" : "Play Música";
            // Efecto visual opcional: si está sonando, podrías cambiar el color
            btn.style.opacity = playing ? "1" : "0.9";
        }

        // 1. Al cargar la página, recuperar estado y segundo exacto
        window.addEventListener('load', () => {
            const isPlaying = localStorage.getItem('musicPlaying') === 'true';
            const currentTime = localStorage.getItem('musicTime');

            if (currentTime) {
                audio.currentTime = parseFloat(currentTime);
            }

            if (isPlaying) {
                // El navegador requiere interacción previa, pero tras el primer clic funciona al navegar
                audio.play()
                    .then(() => actualizarInterfaz(true))
                    .catch(e => {
                        console.log("Autoplay bloqueado. Esperando interacción.");
                        localStorage.setItem('musicPlaying', 'false');
                        actualizarInterfaz(false);
                    });
            }
        });

        // 2. Guardar el tiempo cada segundo para que la música sea "continua"
        setInterval(() => {
            if (!audio.paused) {
                localStorage.setItem('musicTime', audio.currentTime);
            }
        }, 1000);

        // 3. Evento de clic (Toggle Play/Pausa)
        btn.addEventListener('click', () => {
            if (audio.paused) {
                audio.play();
                localStorage.setItem('musicPlaying', 'true');
                actualizarInterfaz(true);
            } else {
                audio.pause();
                localStorage.setItem('musicPlaying', 'false');
                actualizarInterfaz(false);
            }
        });
    </script>
</footer>

